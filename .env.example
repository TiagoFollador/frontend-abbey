# Abbey Gastronomia e Eventos — Environment Variables
# Copy to .env.local for local development (never commit .env.local)

# ─── Site ────────────────────────────────────────────────────────────────────

# Canonical base URL (used for metadataBase, OG URLs, sitemap)
# Production: https://abbeygastronomia.com.br
# Preview:    https://frontend-abbey-*.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Contact / Reservations ─────────────────────────────────────────────────

# WhatsApp number for reservation CTA links (international format, no +)
# Example: 5541999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Restaurant email address (used in contact form fallback)
NEXT_PUBLIC_CONTACT_EMAIL=

# ─── Forms / Notifications ──────────────────────────────────────────────────

# Resend API key for transactional email (event budget requests)
# Get at: https://resend.com/api-keys
RESEND_API_KEY=

# Email address that receives event budget request notifications
RESEND_TO_EMAIL=

# ─── Analytics (optional) ────────────────────────────────────────────────────

# Google Analytics measurement ID (GA4)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Maps (optional) ─────────────────────────────────────────────────────────

# Google Maps embed API key (restricted to your domain)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
